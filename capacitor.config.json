{
  "appId": "app.lifehack.ios",
  "appName": "Life Hack",
  "webDir": ".",
  "bundledWebRuntime": false,
  "server": {
    "androidScheme": "https",
    "iosScheme": "https",
    "hostname": "life-hack-app.vercel.app",
    "url": "https://life-hack-app.vercel.app",
    "cleartext": false,
    "allowNavigation": [
      "life-hack-app.vercel.app",
      "*.life-hack-app.vercel.app",
      "*.plaid.com",
      "cdn.plaid.com"
    ]
  },
  "ios": {
    "contentInset": "always",
    "scrollEnabled": true,
    "limitsNavigationsToAppBoundDomains": false,
    "backgroundColor": "#F7F7F5",
    "preferredContentMode": "mobile"
  },
  "android": {
    "backgroundColor": "#F7F7F5",
    "allowMixedContent": false,
    "captureInput": true,
    "webContentsDebuggingEnabled": false
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1200,
      "launchAutoHide": true,
      "launchFadeOutDuration": 250,
      "backgroundColor": "#F7F7F5",
      "androidScaleType": "CENTER_CROP",
      "showSpinner": false,
      "splashFullScreen": true,
      "splashImmersive": false,
      "useDialog": false
    },
    "StatusBar": {
      "style": "DEFAULT",
      "backgroundColor": "#F7F7F5",
      "overlaysWebView": false
    }
  }
}
