    { "name": "Add spend",  "short_name": "+Spend",  "description": "Log a transaction",                       "url": "/?tab=money&action=add-spend" },
    { "name": "Add a win",  "short_name": "+Win",    "description": "Capture a small victory",                 "url": "/?tab=today&action=add-win" },
    { "name": "Talk to Cornileus", "short_name": "Cornileus", "description": "Open the AI financial counselor", "url": "/?action=counselor" },
    { "name": "Today",      "short_name": "Today",   "description": "Open today's habits and safe-to-spend",   "url": "/?tab=today" }
  ],
  "launch_handler": {
    "client_mode": ["navigate-existing", "auto"]
  },
  "prefer_related_applications": false
